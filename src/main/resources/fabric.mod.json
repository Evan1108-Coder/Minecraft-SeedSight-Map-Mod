{
  "schemaVersion": 1,
  "id": "seedsight",
  "version": "${version}",
  "name": "SeedSight",
  "description": "A minimap mod that reveals terrain, biomes, and structures beyond render distance using seed-based prediction. Includes stats overlay, waypoints, calculator, and sound indicators.",
  "authors": [
    "Evan1108-Coder"
  ],
  "contact": {
    "homepage": "https://github.com/Evan1108-Coder/Minecraft-SeedSight-Map-Mod",
    "sources": "https://github.com/Evan1108-Coder/Minecraft-SeedSight-Map-Mod"
  },
  "license": "MIT",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.seedsight.SeedSightClient"
    ]
  },
  "mixins": [
    "seedsight.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.16.0",
    "fabric-api": "*",
    "minecraft": "~1.21",
    "java": ">=21"
  },
  "suggests": {
    "sodium": "*"
  }
}
